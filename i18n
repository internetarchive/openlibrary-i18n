#!/usr/bin/env python3
"""
Open Library i18n toolbox — ./i18n <command>

  pull [--sync]          Download messages.pot from openlibrary master.
                         --sync also updates all language .po files.
  sync [<lang>]          Update .po file(s) from messages.pot via pybabel.
                         Omit <lang> to sync all known languages.
  incomplete             JSON list of languages with untranslated strings,
                         sorted by count descending.
  batch                  JSON batches to process; one batch = one PR,
                         one language each.
  untranslated <lang>    JSON list of untranslated strings.
    [--limit N]
  apply <lang> <json>    Apply {msgid: msgstr} translations file to .po.
  fix <lang>             Fix HTML attrs and format-string errors in .po.
  validate <lang>        Validate format strings; exits non-zero on error.
  test <lang>            Run pytest tests/test_po_files.py -k <lang>.
  compile <lang>         Compile .po -> .mo via pybabel.
"""
from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
import urllib.request
from pathlib import Path

REPO_ROOT = Path(__file__).parent
LOCALE_DIR = REPO_ROOT / "locale"
MESSAGES_POT = REPO_ROOT / "messages.pot"
TESTS_DIR = REPO_ROOT / "tests"

OL_MESSAGES_POT_URL = (
    "https://raw.githubusercontent.com/internetarchive/openlibrary"
    "/master/openlibrary/i18n/messages.pot"
)


def known_langs() -> list[str]:
    return sorted(
        p.name for p in LOCALE_DIR.iterdir()
        if p.is_dir() and (p / "messages.po").exists()
    )


# ---------------------------------------------------------------------------
# Catalog-level pure functions (no filesystem — fully testable)
# ---------------------------------------------------------------------------

def _stats_from_catalog(catalog, lang: str) -> dict:
    total = fuzzy = translated = 0
    for msg in catalog:
        if not msg.id:
            continue
        total += 1
        if msg.fuzzy:
            fuzzy += 1
        elif isinstance(msg.string, str) and msg.string:
            translated += 1
        elif isinstance(msg.string, (list, tuple)) and any(msg.string):
            translated += 1
    untranslated = total - translated - fuzzy
    return {
        "lang": lang,
        "total": total,
        "translated": translated,
        "untranslated": untranslated,
        "fuzzy": fuzzy,
        "pct": round(100 * translated / total) if total else 0,
    }


def _untranslated_from_catalog(catalog, limit: int | None = None) -> list[dict]:
    entries = []
    for msg in catalog:
        if not msg.id or msg.fuzzy:
            continue
        if isinstance(msg.string, str) and msg.string:
            continue
        if isinstance(msg.string, (list, tuple)) and any(msg.string):
            continue
        entry = (
            {"id": msg.id[0], "id_plural": msg.id[1]}
            if isinstance(msg.id, tuple)
            else {"id": msg.id}
        )
        entries.append(entry)
        if limit and len(entries) >= limit:
            break
    return entries


def _apply_to_catalog(catalog, translations: dict) -> int:
    count = 0
    for msg in catalog:
        if not msg.id:
            continue
        key = msg.id[0] if isinstance(msg.id, tuple) else msg.id
        if key not in translations:
            continue
        val = translations[key]
        if isinstance(msg.id, tuple):
            msg.string = tuple(val) if isinstance(val, list) else (val, val)
        else:
            msg.string = val if isinstance(val, str) else str(val)
        count += 1
    return count


def _fix_html_attrs(catalog) -> int:
    """Add missing HTML attributes to msgstr by comparing with msgid. Returns count fixed."""
    def extract_attrs(tag_str: str) -> dict:
        return dict(re.findall(r'([\w-]+)=["\']([^"\']*)["\']', tag_str))

    def fix_str(msgid_str: str, msgstr_str: str) -> str:
        id_tags = re.findall(r'<([a-zA-Z][^>]*)>', msgid_str)
        str_tags = re.findall(r'<([a-zA-Z][^>]*)>', msgstr_str)
        if len(id_tags) != len(str_tags):
            return msgstr_str
        result = msgstr_str
        for id_tag, str_tag in zip(id_tags, str_tags):
            id_name = id_tag.split()[0] if id_tag.split() else ''
            str_name = str_tag.split()[0] if str_tag.split() else ''
            if id_name.lower() != str_name.lower():
                continue
            missing = {
                k: v for k, v in extract_attrs(id_tag).items()
                if k not in extract_attrs(str_tag)
            }
            if missing:
                new_tag = str_tag + ''.join(f' {k}="{v}"' for k, v in missing.items())
                result = result.replace(f'<{str_tag}>', f'<{new_tag}>', 1)
        return result

    fixed = 0
    for msg in catalog:
        if not msg.id or not msg.string:
            continue
        msgid = msg.id if isinstance(msg.id, str) else msg.id[0]
        if isinstance(msg.string, str):
            new = fix_str(msgid, msg.string)
            if new != msg.string:
                msg.string = new
                fixed += 1
        elif isinstance(msg.string, tuple):
            forms = tuple(fix_str(msgid, f) if f else f for f in msg.string)
            if forms != msg.string:
                msg.string = forms
                fixed += 1
    return fixed


def _fix_format_errors(catalog) -> list[str]:
    """Clear msgstr for entries with placeholder mismatches. Returns list of cleared msgids."""
    def named(s: str) -> set:
        # Include all Python %-format type letters (s, d, f, r, i, u, o, x, e, g, ...)
        return set(re.findall(r'%\((\w+)\)[sdifruoxXeEgGc]', s))

    def positional(s: str) -> list:
        return re.findall(r'(?<!%)%[sdifruoxXeEgGc]', s)

    def mismatch(msgid, msgstr) -> bool:
        if not msgstr:
            return False
        id_s = msgid[0] if isinstance(msgid, tuple) else msgid
        ms_s = (msgstr[0] or '') if isinstance(msgstr, tuple) else msgstr
        id_n, ms_n = named(id_s), named(ms_s)
        if id_n - ms_n or ms_n - id_n:
            return True
        if len(positional(id_s)) != len(positional(ms_s)):
            return True
        if id_n and positional(ms_s) and not ms_n:
            return True
        if isinstance(msgid, tuple) and isinstance(msgstr, tuple):
            for form in msgstr:
                if form and (id_n - named(form)):
                    return True
        return False

    def bad_plural(msgid, msgstr) -> bool:
        if isinstance(msgid, tuple) and isinstance(msgstr, tuple):
            return (len(msgstr) >= 2 and bool(msgstr[0]) and not msgstr[1]) or not any(msgstr)
        return False

    cleared = []
    for msg in catalog:
        if not msg.id or not msg.string:
            continue
        if mismatch(msg.id, msg.string) or bad_plural(msg.id, msg.string):
            msgid_str = msg.id[0] if isinstance(msg.id, tuple) else msg.id
            msg.string = '' if not isinstance(msg.id, tuple) else ('', '')
            msg.flags.discard('fuzzy')
            cleared.append(msgid_str)
    return cleared


def _fix_format_type_mismatch(catalog) -> list[str]:
    """
    Fix named-placeholder type mismatches where names match but type letters differ.
    E.g. msgid has %(n)s but msgstr has %(n)d → replace %(n)d with %(n)s in msgstr.
    Only fixes valid→valid type changes (both must be recognized format specifiers).
    Returns list of fixed msgids.
    """
    _TYPED = re.compile(r'%\((\w+)\)([sdifruoxXeEgGc])')
    _ALL_TYPES = 'sdifruoxXeEgGc'

    def type_map(s: str) -> dict[str, str]:
        return dict(_TYPED.findall(s))

    def apply_types(target: str, id_types: dict) -> str:
        result = target
        for name, id_type in id_types.items():
            for ms_type in _ALL_TYPES:
                if ms_type != id_type:
                    result = result.replace(f'%({name}){ms_type}', f'%({name}){id_type}')
        return result

    fixed = []
    for msg in catalog:
        if not msg.id or not msg.string:
            continue
        # For plural entries, gather types from BOTH singular and plural msgid forms.
        if isinstance(msg.id, tuple):
            id_types = {**type_map(msg.id[0]), **type_map(msg.id[1])}
        else:
            id_types = type_map(msg.id)
        if not id_types:
            continue
        msgid_s = msg.id[0] if isinstance(msg.id, tuple) else msg.id
        if isinstance(msg.string, str):
            new = apply_types(msg.string, id_types)
            if new != msg.string:
                msg.string = new
                fixed.append(msgid_s)
        elif isinstance(msg.string, tuple):
            forms = tuple(apply_types(f, id_types) if f else f for f in msg.string)
            if forms != msg.string:
                msg.string = forms
                fixed.append(msgid_s)
    return fixed


def _fix_validator_failures(catalog) -> list[str]:
    """
    Catch-all: clear any msgstr that still fails full validation after other fixes.
    Uses the same validator as `./i18n validate` so fix→validate is always consistent.
    Returns list of cleared msgids.
    """
    _v = _get_validate_fn()
    cleared = []
    for msg in catalog:
        if not msg.id or not msg.string:
            continue
        if msg.fuzzy:
            continue
        if _v(msg, catalog):
            msgid_s = msg.id[0] if isinstance(msg.id, tuple) else msg.id
            msg.string = '' if not isinstance(msg.id, tuple) else ('', '')
            msg.flags.discard('fuzzy')
            cleared.append(msgid_s)
    return cleared


def _fix_header_fuzzy(catalog) -> int:
    """Remove fuzzy flag from the catalog header (empty msgid). Returns 1 if fixed."""
    if catalog.fuzzy:
        catalog.fuzzy = False
        return 1
    return 0


def _batches_from_counts(counts: list[dict]) -> list[list[str]]:
    """
    Pure function: given counts (list of {lang, untranslated}), return batches.

    Each batch is a single-language list that maps to one PR. Langs with
    untranslated == 0 are excluded. One PR per language keeps each run
    isolated (a stuck or slow language can't crowd out others' turn budget)
    and lets GitHub Actions run every language's job in parallel.
    """
    return [[c["lang"]] for c in counts if c["untranslated"] > 0]


# ---------------------------------------------------------------------------
# File-level functions
# ---------------------------------------------------------------------------

def _read_po(lang: str):
    from babel.messages.pofile import read_po
    with open(LOCALE_DIR / lang / "messages.po", "rb") as f:
        return read_po(f)


def _write_po(lang: str, catalog) -> None:
    from babel.messages.pofile import write_po
    with open(LOCALE_DIR / lang / "messages.po", "wb") as f:
        write_po(f, catalog, width=10000, omit_header=False)


def get_counts(lang: str) -> dict:
    return _stats_from_catalog(_read_po(lang), lang)


def get_untranslated(lang: str, limit: int | None = None) -> list[dict]:
    return _untranslated_from_catalog(_read_po(lang), limit)


def apply_translations(lang: str, translations: dict) -> int:
    catalog = _read_po(lang)
    count = _apply_to_catalog(catalog, translations)
    _write_po(lang, catalog)
    return count


def fix(lang: str) -> tuple[int, int]:
    """Fix HTML attrs, format-string errors, type mismatches, and header fuzzy flag.
    Returns (html_fixed, format_cleared_count)."""
    catalog = _read_po(lang)
    _fix_header_fuzzy(catalog)
    html = _fix_html_attrs(catalog)
    type_fixed = _fix_format_type_mismatch(catalog)
    cleared_ids = _fix_format_errors(catalog)
    validator_cleared = _fix_validator_failures(catalog)
    _write_po(lang, catalog)
    # Print details for any cleared or type-fixed entries so runs are auditable.
    for msgid in type_fixed:
        print(f"  type-fixed: {msgid!r}")
    for msgid in cleared_ids + validator_cleared:
        print(f"  cleared: {msgid!r}")
    return html, len(cleared_ids) + len(validator_cleared)


_validators_validate = None


def _get_validate_fn():
    global _validators_validate
    if _validators_validate is None:
        import importlib.util
        from importlib.machinery import SourceFileLoader
        path = TESTS_DIR / "validators.py"
        loader = SourceFileLoader("i18n_validators", str(path))
        spec = importlib.util.spec_from_file_location("i18n_validators", path, loader=loader)
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)
        _validators_validate = mod.validate
    return _validators_validate


def validate(lang: str) -> list[tuple]:
    """Returns list of (msgid, errors). Empty list means valid."""
    _v = _get_validate_fn()
    catalog = _read_po(lang)
    errors = []
    for msg in catalog:
        if not msg.id:
            continue
        errs = _v(msg, catalog)
        if errs:
            errors.append((msg.id, errs))
    return errors


def get_incomplete() -> list[dict]:
    """Return langs with untranslated > 0, sorted by count descending."""
    counts = [get_counts(lang) for lang in known_langs()]
    return sorted(
        [{"lang": c["lang"], "untranslated": c["untranslated"]} for c in counts if c["untranslated"] > 0],
        key=lambda c: c["untranslated"],
        reverse=True,
    )


def get_batches() -> list[list[str]]:
    counts = [get_counts(lang) for lang in known_langs()]
    return _batches_from_counts(counts)


# ---------------------------------------------------------------------------
# Subprocess commands
# ---------------------------------------------------------------------------

def pull(*, sync_all: bool = False) -> None:
    with urllib.request.urlopen(OL_MESSAGES_POT_URL) as resp:
        MESSAGES_POT.write_bytes(resp.read())
    print("→ download messages.pot")
    if sync_all:
        for lang in known_langs():
            sync(lang)


def sync(lang: str) -> None:
    print(f"→ pybabel update {lang}")
    # Use --output-file (not --output-dir) — our layout is locale/{lang}/messages.po,
    # not locale/{lang}/LC_MESSAGES/messages.po.
    subprocess.run(
        [sys.executable, "-m", "babel.messages.frontend", "update",
         "--input-file", str(MESSAGES_POT),
         "--output-file", str(LOCALE_DIR / lang / "messages.po"),
         "--locale", lang,
         "--no-fuzzy-matching"],
        check=True, cwd=REPO_ROOT,
        stderr=subprocess.DEVNULL,
    )
    # pybabel carries over an existing fuzzy flag on the header; strip it so
    # compile doesn't refuse with "catalog is marked as fuzzy, skipping".
    from babel.messages.pofile import read_po, write_po
    po_path = LOCALE_DIR / lang / "messages.po"
    with open(po_path, "rb") as f:
        catalog = read_po(f)
    if _fix_header_fuzzy(catalog):
        with open(po_path, "wb") as f:
            write_po(f, catalog, width=10000, omit_header=False)


def compile_po(lang: str) -> None:
    print(f"→ pybabel compile {lang}")
    subprocess.run(
        [sys.executable, "-m", "babel.messages.frontend", "compile",
         "--input-file", str(LOCALE_DIR / lang / "messages.po"),
         "--output-file", str(LOCALE_DIR / lang / "messages.mo"),
         "--locale", lang],
        check=True, cwd=REPO_ROOT,
    )


def run_tests(lang: str) -> None:
    print(f"→ pytest tests/test_po_files.py -k {lang}")
    subprocess.run(
        [sys.executable, "-m", "pytest", "tests/test_po_files.py", "-k", lang, "-q"],
        check=True, cwd=REPO_ROOT,
    )


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Open Library i18n toolbox",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("pull", help="Download messages.pot from openlibrary master")
    p.add_argument("--sync", action="store_true", help="Also sync all language .po files")

    p = sub.add_parser("sync", help="Update .po file(s) from messages.pot")
    p.add_argument("lang", nargs="?", default=None, help="Language code; omit to sync all")

    sub.add_parser("incomplete", help="JSON list of languages with untranslated strings")

    sub.add_parser("batch", help="JSON batches to process (one batch = one PR)")

    p = sub.add_parser("untranslated", help="JSON list of untranslated strings for a language")
    p.add_argument("lang")
    p.add_argument("--limit", type=int, default=None)

    p = sub.add_parser("apply", help="Apply {msgid: msgstr} JSON file to .po")
    p.add_argument("lang")
    p.add_argument("json_file")

    p = sub.add_parser("fix", help="Fix HTML attrs and format-string errors")
    p.add_argument("lang")

    p = sub.add_parser("validate", help="Validate format strings (exits non-zero on error)")
    p.add_argument("lang")

    p = sub.add_parser("test", help="Run pytest for a language")
    p.add_argument("lang")

    p = sub.add_parser("compile", help="Compile .po -> .mo")
    p.add_argument("lang")

    args = parser.parse_args()

    if args.cmd == "pull":
        pull(sync_all=args.sync)

    elif args.cmd == "sync":
        langs = [args.lang] if args.lang else known_langs()
        for lang in langs:
            sync(lang)

    elif args.cmd == "incomplete":
        print(json.dumps(get_incomplete(), ensure_ascii=False, indent=2))

    elif args.cmd == "batch":
        batches = get_batches()
        print(json.dumps({"batches": batches}, ensure_ascii=False, indent=2))

    elif args.cmd == "untranslated":
        print(json.dumps(get_untranslated(args.lang, args.limit),
                         ensure_ascii=False, indent=2))

    elif args.cmd == "apply":
        translations = json.loads(Path(args.json_file).read_text(encoding="utf-8"))
        count = apply_translations(args.lang, translations)
        print(f"Applied: {count}")

    elif args.cmd == "fix":
        html, fmt = fix(args.lang)
        print(f"{args.lang}: {html} HTML attr fixed, {fmt} format errors cleared")

    elif args.cmd == "validate":
        errors = validate(args.lang)
        if errors:
            for msgid, errs in errors[:10]:
                print(f"error: {msgid!r}")
                for e in errs:
                    print(f"  {e}")
            sys.exit(f"{args.lang}: {len(errors)} error(s)")
        print(f"{args.lang}: OK")

    elif args.cmd == "test":
        run_tests(args.lang)

    elif args.cmd == "compile":
        compile_po(args.lang)


if __name__ == "__main__":
    main()
